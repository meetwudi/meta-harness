{
  "name": "@meta-harness/librarian",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm --prefix ../../storage/impl run build",
    "build": "../../knowledge-agent/impl/node_modules/.bin/tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node dist/filesystem-storage-end-to-end.test.js",
    "preintegration:filesystem-storage-end-to-end": "npm run build",
    "integration:filesystem-storage-end-to-end": "node dist/filesystem-storage-end-to-end.test.js",
    "preintegration:postgres-storage": "npm run build",
    "integration:postgres-storage": "node dist/postgres-storage-end-to-end.test.js",
    "preintegration:storage-spec-manifest": "npm --prefix ../../storage/impl run integration:storage-spec-manifest && npm run build",
    "integration:storage-spec-manifest": "node dist/storage-spec-manifest.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
