#!/usr/bin/env python3
import argparse
import ast
import re
import sys
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    tomllib = None


REQUIRED_FIELDS = {
    "items": list,
}

ITEM_ID_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
ALLOWED_TOP_LEVEL_FIELDS = {"items"}
SUBAGENT_NOTICE = "# Harness-Compliance: Review applicable compliance with an independent subagent before attesting."


def fail(failures, message):
    failures.append(message)


def relative(repo_root, path):
    return str(path.relative_to(repo_root)).replace("\\", "/")


def strip_comment(line):
    in_string = False
    result = []
    for char in line:
        if char == '"':
            in_string = not in_string
        if char == "#" and not in_string:
            break
        result.append(char)
    return "".join(result).strip()


def parse_value(raw):
    raw = raw.strip()
    if raw.startswith("["):
        return ast.literal_eval(raw)
    if raw.startswith('"') and raw.endswith('"'):
        return ast.literal_eval(raw)
    return raw


def parse_minimal_toml(text):
    data = {}
    current = data
    pending_key = None
    pending_lines = []

    def finish_pending():
        nonlocal pending_key, pending_lines, current
        if pending_key is None:
            return
        current[pending_key] = parse_value("\n".join(pending_lines))
        pending_key = None
        pending_lines = []

    for raw_line in text.splitlines():
        line = strip_comment(raw_line)
        if not line:
            continue
        if pending_key is not None:
            pending_lines.append(line)
            if line.endswith("]"):
                finish_pending()
            continue
        if line.startswith("[[") and line.endswith("]]"):
            finish_pending()
            table = line.strip("[]")
            item = {}
            data.setdefault(table, []).append(item)
            current = item
            continue
        if line.startswith("[") and line.endswith("]"):
            finish_pending()
            table = line.strip("[]")
            current = data.setdefault(table, {})
            continue
        if "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if value.startswith("[") and not value.endswith("]"):
            pending_key = key
            pending_lines = [value]
            continue
        current[key] = parse_value(value)

    finish_pending()
    return data


def load_toml(path, failures):
    try:
        if tomllib is not None:
            return tomllib.loads(path.read_text())
        return parse_minimal_toml(path.read_text())
    except Exception as exc:
        fail(failures, f"{path}: invalid TOML: {exc}")
    return None


def validate_items(path, items, failures):
    if not isinstance(items, list):
        return
    if not items:
        fail(failures, f"{path}: items must not be empty")
        return

    seen_ids = set()
    for index, item in enumerate(items, start=1):
        if not isinstance(item, dict):
            fail(failures, f"{path}: items entry {index} must be a table")
            continue

        item_id = item.get("id")
        text = item.get("text")
        if not isinstance(item_id, str) or not item_id.strip():
            fail(failures, f"{path}: items entry {index} id must be a non-empty string")
        elif not ITEM_ID_RE.match(item_id):
            fail(failures, f"{path}: item id must use lowercase letters, numbers, and hyphens: {item_id}")
        elif item_id in seen_ids:
            fail(failures, f"{path}: duplicate item id: {item_id}")
        else:
            seen_ids.add(item_id)

        if not isinstance(text, str) or not text.strip():
            fail(failures, f"{path}: item {item_id or index} text must be a non-empty string")

        comment = item.get("comment")
        if comment is not None and (not isinstance(comment, str) or not comment.strip()):
            fail(failures, f"{path}: item {item_id or index} comment must be a non-empty string when present")


def validate_subagent_notice(compliance_toml, failures):
    lines = compliance_toml.read_text().splitlines()
    first_content = next((line.strip() for line in lines if line.strip()), "")
    if first_content != SUBAGENT_NOTICE:
        fail(failures, f"{compliance_toml}: first content line must be {SUBAGENT_NOTICE!r}")


def validate_compliance(repo_root, compliance_toml, failures):
    validate_subagent_notice(compliance_toml, failures)
    data = load_toml(compliance_toml, failures)
    if data is None:
        return
    if not isinstance(data, dict):
        fail(failures, f"{compliance_toml}: top-level value must be a table")
        return

    for field, expected_type in REQUIRED_FIELDS.items():
        value = data.get(field)
        if not isinstance(value, expected_type) or (expected_type is str and not value.strip()):
            fail(failures, f"{compliance_toml}: {field} must be a non-empty {expected_type.__name__}")

    for field in sorted(set(data) - ALLOWED_TOP_LEVEL_FIELDS):
        fail(failures, f"{compliance_toml}: only items may be defined at the top level")

    validate_items(compliance_toml, data.get("items"), failures)


def main():
    parser = argparse.ArgumentParser(description="Verify Meta Harness compliance definitions.")
    parser.add_argument("--repo-root", default=".")
    args = parser.parse_args()

    repo_root = Path(args.repo_root).resolve()
    failures = []
    compliance_files = sorted(repo_root.rglob("COMPLIANCE.toml"))

    if not compliance_files:
        print("Meta Harness compliance definitions passed: no COMPLIANCE.toml files.")
        return 0

    for compliance_toml in compliance_files:
        validate_compliance(repo_root, compliance_toml, failures)

    if failures:
        print("Meta Harness compliance definition check failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print(f"Meta Harness compliance definitions passed for {len(compliance_files)} file(s).")
    return 0


if __name__ == "__main__":
    sys.exit(main())
