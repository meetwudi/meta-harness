#!/usr/bin/env python3
import argparse
import ast
import json
import re
import subprocess
import sys
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    tomllib = None


REQUIRED_REPO_FILES = (
    ".meta-harness.json",
    ".gitignore",
    "AGENTS.md",
    "COMPLIANCE.toml",
    "meta-harness/AGENTS.md",
    "harness/AGENTS.md",
)

REQUIRED_PROJECT_HARNESS_FILES = (
    "harness/AGENTS.md",
    "harness/routines/AGENTS.md",
)

REQUIRED_LIBRARY_LOCATIONS = {
    "repository": ".",
    "meta-harness": "meta-harness",
    "project-harness": "harness",
}

PROJECT_NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")
STORAGE_CAPABILITIES = {"read", "write", "delete", "query", "blob"}
STORAGE_DISCOVERY_MODES = {
    "filesystem-root-and-direct-children",
    "filesystem-recursive",
}

DELEGATED_CHECKS = (
    "check-library-definitions",
    "check-routine-definitions",
    "check-memory-definitions",
    "check-compliance-definitions",
    "check-skill-definitions",
    "check-harness-file-metadata",
)


def fail(failures, message):
    failures.append(message)


def relative(path):
    return str(path).replace("\\", "/")


def load_json(path, failures):
    try:
        return json.loads(path.read_text())
    except Exception as exc:
        fail(failures, f"{relative(path)}: invalid JSON: {exc}")
    return None


def strip_comment(line):
    in_string = False
    result = []
    for char in line:
        if char == '"':
            in_string = not in_string
        if char == "#" and not in_string:
            break
        result.append(char)
    return "".join(result).strip()


def parse_value(raw):
    raw = raw.strip()
    if raw.startswith("["):
        return ast.literal_eval(raw)
    if raw.startswith('"') and raw.endswith('"'):
        return ast.literal_eval(raw)
    return raw


def parse_minimal_toml(text):
    data = {}
    current = data
    pending_key = None
    pending_lines = []

    def finish_pending():
        nonlocal pending_key, pending_lines, current
        if pending_key is None:
            return
        current[pending_key] = parse_value("\n".join(pending_lines))
        pending_key = None
        pending_lines = []

    for raw_line in text.splitlines():
        line = strip_comment(raw_line)
        if not line:
            continue
        if pending_key is not None:
            pending_lines.append(line)
            if line.endswith("]"):
                finish_pending()
            continue
        if line.startswith("[[") and line.endswith("]]"):
            finish_pending()
            table = line.strip("[]")
            item = {}
            data.setdefault(table, []).append(item)
            current = item
            continue
        if line.startswith("[") and line.endswith("]"):
            finish_pending()
            table = line.strip("[]")
            current = data.setdefault(table, {})
            continue
        if "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if value.startswith("[") and not value.endswith("]"):
            pending_key = key
            pending_lines = [value]
            continue
        current[key] = parse_value(value)

    finish_pending()
    return data


def load_toml(path, failures):
    try:
        if tomllib is not None:
            return tomllib.loads(path.read_text())
        return parse_minimal_toml(path.read_text())
    except Exception as exc:
        fail(failures, f"{relative(path)}: invalid TOML: {exc}")
    return None


def validate_meta_harness_marker(repo_root, failures):
    marker = repo_root / ".meta-harness.json"
    data = load_json(marker, failures)
    if data is None:
        return

    if data.get("schema") != 1:
        fail(failures, ".meta-harness.json: schema must be 1")

    project = data.get("project")
    if not isinstance(project, dict):
        fail(failures, ".meta-harness.json: project must be an object")
    else:
        name = project.get("name")
        if not isinstance(name, str) or not name.strip():
            fail(failures, ".meta-harness.json: project.name must be a non-empty string")
        elif name in {".", ".."} or "/" in name or "\\" in name or not PROJECT_NAME_RE.match(name):
            fail(
                failures,
                ".meta-harness.json: project.name must be filesystem-safe "
                "(letters, numbers, dot, underscore, and dash)",
            )

        local_root = project.get("localRoot")
        if not isinstance(local_root, str) or not local_root.strip():
            fail(failures, ".meta-harness.json: project.localRoot must be a non-empty string")

    source = data.get("source")
    if not isinstance(source, dict):
        fail(failures, ".meta-harness.json: source must be an object")
        return

    for field in ("type", "url", "ref"):
        value = source.get(field)
        if not isinstance(value, str) or not value.strip():
            fail(failures, f".meta-harness.json: source.{field} must be a non-empty string")

    validate_storage_locations(data, failures)


def validate_storage_locations(data, failures):
    storage = data.get("storage")
    if not isinstance(storage, dict):
        fail(failures, ".meta-harness.json: storage must be an object")
        return

    locations = storage.get("locations")
    if not isinstance(locations, list) or not locations:
        fail(failures, ".meta-harness.json: storage.locations must be a non-empty array")
        return

    seen_names = set()
    for index, location in enumerate(locations):
        prefix = f".meta-harness.json: storage.locations[{index}]"
        if not isinstance(location, dict):
            fail(failures, f"{prefix} must be an object")
            continue

        name = location.get("name")
        if not isinstance(name, str) or not name.strip():
            fail(failures, f"{prefix}.name must be a non-empty string")
        elif name in seen_names:
            fail(failures, f"{prefix}.name duplicates storage location {name}")
        else:
            seen_names.add(name)

        for field in ("description", "driverName", "libraryRootPath", "guidanceUri"):
            value = location.get(field)
            if not isinstance(value, str) or not value.strip():
                fail(failures, f"{prefix}.{field} must be a non-empty string")

        source_uri = location.get("sourceUri")
        if source_uri is not None and (not isinstance(source_uri, str) or not source_uri.strip()):
            fail(failures, f"{prefix}.sourceUri must be a non-empty string when present")

        discovery_mode = location.get("discoveryMode")
        if discovery_mode not in STORAGE_DISCOVERY_MODES:
            fail(failures, f"{prefix}.discoveryMode must be one of {sorted(STORAGE_DISCOVERY_MODES)}")

        discover_libraries = location.get("discoverLibraries")
        if not isinstance(discover_libraries, bool):
            fail(failures, f"{prefix}.discoverLibraries must be a boolean")

        discovery_excludes = location.get("discoveryExcludes")
        if (
            not isinstance(discovery_excludes, list)
            or any(not isinstance(item, str) or not item.strip() for item in discovery_excludes)
        ):
            fail(failures, f"{prefix}.discoveryExcludes must be an array of non-empty strings")

        grants = location.get("grants")
        if not isinstance(grants, list) or not grants:
            fail(failures, f"{prefix}.grants must be a non-empty array")
            continue
        validate_storage_grants(prefix, grants, failures)


def validate_storage_grants(prefix, grants, failures):
    for index, grant in enumerate(grants):
        grant_prefix = f"{prefix}.grants[{index}]"
        if not isinstance(grant, dict):
            fail(failures, f"{grant_prefix} must be an object")
            continue

        actors = grant.get("actors")
        if not isinstance(actors, list) or not actors:
            fail(failures, f"{grant_prefix}.actors must be a non-empty array")
        else:
            for actor in actors:
                if not isinstance(actor, str) or not actor.strip():
                    fail(failures, f"{grant_prefix}.actors must contain non-empty strings")
                elif not actor.startswith("actor://"):
                    fail(failures, f"{grant_prefix}.actors must use actor://: {actor}")

        capabilities = grant.get("capabilities")
        if not isinstance(capabilities, list) or not capabilities:
            fail(failures, f"{grant_prefix}.capabilities must be a non-empty array")
            continue

        for capability in capabilities:
            if capability not in STORAGE_CAPABILITIES:
                fail(
                    failures,
                    f"{grant_prefix}.capabilities has unsupported capability {capability!r}",
                )


def validate_required_files(repo_root, failures):
    required_files = dict.fromkeys(REQUIRED_REPO_FILES + REQUIRED_PROJECT_HARNESS_FILES)
    for required in required_files:
        path = repo_root / required
        if not path.is_file():
            fail(failures, f"{required}: required file is missing")

    for required_dir in ("meta-harness", "harness"):
        path = repo_root / required_dir
        if not path.is_dir():
            fail(failures, f"{required_dir}: required directory is missing")


def validate_required_libraries(repo_root, failures):
    by_name = {}
    for manifest in repo_root.rglob("LIBRARY.toml"):
        parts = manifest.relative_to(repo_root).parts
        if ".git" in parts or parts[:2] == ("meta-harness", "templates"):
            continue
        data = load_toml(manifest, failures)
        if isinstance(data, dict) and isinstance(data.get("name"), str):
            by_name[data["name"]] = manifest.parent

    for name, expected_location in REQUIRED_LIBRARY_LOCATIONS.items():
        root = by_name.get(name)
        if root is None:
            fail(failures, f"missing required Library {name}")
            continue

        actual_location = root.relative_to(repo_root).as_posix()
        if actual_location == "":
            actual_location = "."
        if actual_location != expected_location:
            fail(
                failures,
                f"Library {name} location must be {expected_location}",
            )


def run_delegated_check(repo_root, tool_name, failures):
    tool = repo_root / "meta-harness" / "tools" / tool_name
    if not tool.is_file():
        fail(failures, f"meta-harness/tools/{tool_name}: delegated check is missing")
        return

    result = subprocess.run(
        [sys.executable, str(tool), "--repo-root", str(repo_root)],
        check=False,
        capture_output=True,
        text=True,
    )

    if result.returncode == 0:
        return

    output = "\n".join(
        line for line in (result.stderr + result.stdout).splitlines() if line.strip()
    )
    if output:
        fail(failures, f"{tool_name} failed:\n{output}")
    else:
        fail(failures, f"{tool_name} failed with exit code {result.returncode}")


def main():
    parser = argparse.ArgumentParser(
        description="Verify project-specific harness compliance with Meta Harness."
    )
    parser.add_argument("--repo-root", default=".")
    args = parser.parse_args()

    repo_root = Path(args.repo_root).resolve()
    failures = []

    validate_required_files(repo_root, failures)
    if (repo_root / ".meta-harness.json").is_file():
        validate_meta_harness_marker(repo_root, failures)
    validate_required_libraries(repo_root, failures)

    for tool_name in DELEGATED_CHECKS:
        run_delegated_check(repo_root, tool_name, failures)

    if failures:
        print("Meta Harness project harness compliance check failed:", file=sys.stderr)
        for failure in failures:
            for line in failure.splitlines():
                print(f"- {line}", file=sys.stderr)
        return 1

    print("Meta Harness project harness compliance passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
