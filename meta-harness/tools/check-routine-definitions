#!/usr/bin/env python3
import argparse
import ast
import re
import sys
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    tomllib = None


REQUIRED_FIELDS = {
    "name": str,
    "source_library": str,
    "purpose": str,
    "libraries": list,
    "procedure": list,
    "completion_evidence": list,
}

LIST_FIELDS = (
    "libraries",
    "procedure",
    "outcomes",
    "completion_evidence",
)

LIBRARY_REFERENCE_FIELDS = (
    "source_library",
    "libraries",
)

MEMORY_REFERENCE_FIELDS = (
    "per_execution_memory_library",
    "cross_execution_memory_library",
)
LIBRARY_NAME_PATTERN = re.compile(r"^[a-z0-9]+(?:[-_][a-z0-9]+)*$")
LIBRARY_NAME_FORMAT = "lowercase letters and digits separated by hyphens or underscores"


def fail(failures, message):
    failures.append(message)


def strip_comment(line):
    in_string = False
    result = []
    for char in line:
        if char == '"':
            in_string = not in_string
        if char == "#" and not in_string:
            break
        result.append(char)
    return "".join(result).strip()


def parse_value(raw):
    raw = raw.strip()
    if raw.startswith("["):
        return ast.literal_eval(raw)
    if raw.startswith('"') and raw.endswith('"'):
        return ast.literal_eval(raw)
    return raw


def parse_minimal_toml(text):
    data = {}
    pending_key = None
    pending_lines = []

    def finish_pending():
        nonlocal pending_key, pending_lines
        if pending_key is None:
            return
        data[pending_key] = parse_value("\n".join(pending_lines))
        pending_key = None
        pending_lines = []

    for raw_line in text.splitlines():
        line = strip_comment(raw_line)
        if not line:
            continue
        if pending_key is not None:
            pending_lines.append(line)
            if line.endswith("]"):
                finish_pending()
            continue
        if "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        if value.startswith("[") and not value.endswith("]"):
            pending_key = key
            pending_lines = [value]
            continue
        data[key] = parse_value(value)

    finish_pending()
    return data


def load_toml(path, failures):
    try:
        if tomllib is not None:
            return tomllib.loads(path.read_text())
        return parse_minimal_toml(path.read_text())
    except Exception as exc:
        fail(failures, f"{path}: invalid TOML: {exc}")
    return None


def validate_string_list(path, data, field, failures):
    value = data.get(field, [])
    if not isinstance(value, list):
        fail(failures, f"{path}: {field} must be a list")
        return
    if not value and field in REQUIRED_FIELDS:
        fail(failures, f"{path}: {field} must not be empty")
    bad = [item for item in value if not isinstance(item, str) or not item.strip()]
    if bad:
        fail(failures, f"{path}: {field} must contain only non-empty strings")


def validate_library_reference(path, field, value, failures):
    if not isinstance(value, str):
        return
    if not value.startswith("library://"):
        fail(failures, f"{path}: {field} must use library://")
        return
    name = value.removeprefix("library://")
    if not name or "/" in name:
        fail(failures, f"{path}: {field} must reference a Library name, not a Library path: {value}")
        return
    if not LIBRARY_NAME_PATTERN.fullmatch(name):
        fail(failures, f"{path}: {field} Library name must use {LIBRARY_NAME_FORMAT}: {value}")


def validate_memory_reference(path, field, value, failures):
    if value is None:
        return
    if not isinstance(value, str) or not value.strip():
        fail(failures, f"{path}: {field} must be a non-empty string")
        return
    if not value.startswith("library://"):
        fail(failures, f"{path}: {field} must use library://")
        return
    suffix = value.removeprefix("library://").strip("/")
    name = suffix.split("/", 1)[0]
    if not LIBRARY_NAME_PATTERN.fullmatch(name):
        fail(failures, f"{path}: {field} Library name must use {LIBRARY_NAME_FORMAT}: {value}")


def validate_routine(routine_dir, failures):
    agents = routine_dir / "AGENTS.md"
    routine_toml = routine_dir / "ROUTINE.toml"

    for required in (agents, routine_toml):
        if not required.is_file():
            fail(failures, f"{routine_dir}: missing {required.name}")
            return

    data = load_toml(routine_toml, failures)
    if data is None:
        return
    if not isinstance(data, dict):
        fail(failures, f"{routine_toml}: top-level value must be a table")
        return

    for field, expected_type in REQUIRED_FIELDS.items():
        value = data.get(field)
        if not isinstance(value, expected_type) or (expected_type is str and not value.strip()):
            fail(failures, f"{routine_toml}: {field} must be a non-empty {expected_type.__name__}")

    for field in LIST_FIELDS:
        validate_string_list(routine_toml, data, field, failures)

    name = data.get("name")
    if isinstance(name, str) and name != routine_dir.name:
        fail(failures, f"{routine_toml}: name must match directory name {routine_dir.name}")

    for field in LIBRARY_REFERENCE_FIELDS:
        value = data.get(field)
        if isinstance(value, list):
            for item in value:
                validate_library_reference(routine_toml, field, item, failures)
        else:
            validate_library_reference(routine_toml, field, value, failures)

    for field in MEMORY_REFERENCE_FIELDS:
        validate_memory_reference(routine_toml, field, data.get(field), failures)


def repository_library_roots(repo_root):
    ignored_roots = {".git"}
    for path in sorted(repo_root.rglob("LIBRARY.toml")):
        parts = path.relative_to(repo_root).parts
        if any(part in ignored_roots for part in parts):
            continue
        if parts[:2] == ("meta-harness", "templates"):
            continue
        yield path.parent


def repository_routine_roots(repo_root):
    seen = set()
    for library_root in repository_library_roots(repo_root):
        routines_root = library_root / "routines"
        if not routines_root.exists():
            continue
        if routines_root in seen:
            continue
        seen.add(routines_root)
        yield routines_root


def relative(repo_root, path):
    return str(path.relative_to(repo_root)).replace("\\", "/")


def main():
    parser = argparse.ArgumentParser(description="Verify Meta Harness Routine definitions.")
    parser.add_argument("--repo-root", default=".")
    args = parser.parse_args()

    repo_root = Path(args.repo_root).resolve()
    failures = []
    routine_roots = list(repository_routine_roots(repo_root))

    if not routine_roots:
        print("Meta Harness Routine definitions passed: no repository routines found.")
        return 0

    count = 0
    for routines_root in routine_roots:
        if not routines_root.is_dir():
            fail(failures, f"{relative(repo_root, routines_root)}: must be a directory")
            continue
        if not (routines_root / "AGENTS.md").is_file():
            fail(failures, f"{relative(repo_root, routines_root)}: missing AGENTS.md")
        for routine_dir in sorted(path for path in routines_root.iterdir() if path.is_dir()):
            validate_routine(routine_dir, failures)
            count += 1

    if failures:
        print("Meta Harness Routine definition check failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print(f"Meta Harness Routine definitions passed for {count} routine(s).")
    return 0


if __name__ == "__main__":
    sys.exit(main())
