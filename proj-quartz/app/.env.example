# Harness-Requirement: proj-quartz.local-postgres-deployment
# Copy this file to `../.env` for local Quartz development.
# Keep `../.env` out of git.

QUARTZ_REPO_ROOT=../..
QUARTZ_PROJECT_CONFIG=proj-quartz/.meta-harness.json
QUARTZ_POSTGRES_URL=postgresql://quartz:quartz@127.0.0.1:5433/quartz
QUARTZ_PUBLIC_BASE_URL=http://127.0.0.1:3000

# Required for Google sign-in.
QUARTZ_GOOGLE_CLIENT_ID=...
QUARTZ_GOOGLE_CLIENT_SECRET=...
# Defaults to `${QUARTZ_PUBLIC_BASE_URL}/api/auth/google/callback`.
# QUARTZ_GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/auth/google/callback

# Invite email delivery through Resend.
QUARTZ_RESEND_API_KEY=...
QUARTZ_RESEND_FROM="Quartz <invite@example.com>"

# Optional invite email delivery webhook. The app posts `{ to, subject, text }`.
# Used only when `QUARTZ_RESEND_API_KEY` is unset.
# QUARTZ_INVITE_EMAIL_WEBHOOK_URL=https://example.invalid/send
# QUARTZ_INVITE_EMAIL_WEBHOOK_BEARER=...
# Local acceptance/debugging link mode for environments without email delivery.
# QUARTZ_INVITE_LINK_DEV_MODE=true

# Required for the OpenAI-backed Knowledge Agent.
OPENAI_API_KEY=sk-...

# Optional Knowledge Agent overrides.
# KNOWLEDGE_AGENT_MODEL=gpt-5.4-mini
# `KNOWLEDGE_AGENT_MODEL` must match one of the configured
# `knowledgeAgent.modelOptions` in `../.meta-harness.json`.
# KNOWLEDGE_AGENT_PROVIDER=openai
# KNOWLEDGE_AGENT_REASONING_EFFORT=medium
# KNOWLEDGE_AGENT_SANDBOX_CLIENT=unix
# QUARTZ_KNOWLEDGE_AGENT_TIMEOUT_MS=180000
