{
  "schema": 1,
  "project": {
    "name": "proj-quartz",
    "localRoot": "~/.proj-quartz",
    "actorUri": "actor://proj-quartz/agent"
  },
  "runtime": {
    "conversationStorage": {
      "driverName": "postgres",
      "connectionStringEnv": "QUARTZ_POSTGRES_URL",
      "schemaName": "meta_harness",
      "tableName": "resources"
    },
    "conversationLibrary": {
      "name": "knowledge-agent-conversations",
      "rootPath": "/libraries/knowledge-agent-conversations"
    },
    "memoryCurator": {
      "enabled": true,
      "actorUri": "actor://proj-quartz/memory-curator",
      "recentMessageLimit": 10,
      "latestUserMessageOnly": true
    },
    "sharedMemory": {
      "enabled": false
    }
  },
  "knowledgeAgent": {
    "defaultModel": "gpt-5.4-mini",
    "modelOptions": [
      {
        "id": "gpt-5.4-mini",
        "label": "GPT-5.4 Mini"
      },
      {
        "id": "gpt-5.4",
        "label": "GPT-5.4"
      }
    ]
  },
  "libraryCreation": {
    "policyUri": "library://proj-quartz/harness/LIBRARY-CREATION.toml"
  },
  "storage": {
    "locations": [
      {
        "name": "meta-harness-framework",
        "description": "Checked-in Meta Harness framework knowledge needed by PROJ-Quartz agents.",
        "driverName": "filesystem",
        "grants": [
          {
            "actors": [
              "actor://proj-quartz/agent",
              "actor://proj-quartz/memory-curator"
            ],
            "capabilities": ["read", "query", "blob"]
          }
        ],
        "libraryRootPath": "{{repoRootPath}}/meta-harness",
        "discoveryMode": "filesystem-root-and-direct-children",
        "discoveryExcludes": [
          "templates",
          "templates/**",
          "knowledge-agent/impl/node_modules",
          "knowledge-agent/impl/node_modules/**",
          "knowledge-agent/impl/dist",
          "knowledge-agent/impl/dist/**",
          "librarian/impl/dist",
          "librarian/impl/dist/**"
        ],
        "discoverLibraries": true,
        "sourceUri": "library://proj-quartz/.meta-harness.json",
        "guidanceUri": "library://meta-harness/storage/STORAGE.md"
      },
      {
        "name": "project",
        "description": "PROJ-Quartz project knowledge and application files.",
        "driverName": "filesystem",
        "grants": [
          {
            "actors": [
              "actor://proj-quartz/agent",
              "actor://proj-quartz/memory-curator"
            ],
            "capabilities": ["read", "query", "blob"]
          }
        ],
        "libraryRootPath": "{{projectRootPath}}",
        "discoveryMode": "filesystem-root-and-direct-children",
        "discoveryExcludes": [
          "app/node_modules",
          "app/node_modules/**",
          "app/vendor",
          "app/vendor/**",
          "app/.next",
          "app/.next/**"
        ],
        "discoverLibraries": true,
        "sourceUri": "library://proj-quartz/.meta-harness.json",
        "guidanceUri": "library://meta-harness/storage/STORAGE.md"
      },
      {
        "name": "quartz-postgres",
        "description": "PROJ-Quartz Postgres-backed storage location for database-backed Libraries.",
        "driverName": "postgres",
        "enabledWhenEnv": "QUARTZ_POSTGRES_URL",
        "connectionStringEnv": "QUARTZ_POSTGRES_URL",
        "schemaName": "meta_harness",
        "tableName": "resources",
        "grants": [
          {
            "actors": [
              "actor://proj-quartz/agent",
              "actor://proj-quartz/memory-curator"
            ],
            "capabilities": ["read", "write", "delete", "query"]
          }
        ],
        "libraryRootPath": "/libraries",
        "discoveryMode": "resource-root-and-direct-children",
        "discoveryExcludes": [],
        "discoverLibraries": true,
        "defaultForLibraryCreation": true,
        "createdLibraryReadActors": [
          "actor://proj-quartz/agent",
          "actor://proj-quartz/memory-curator"
        ],
        "createdLibraryUpdateActors": [
          "actor://proj-quartz/agent",
          "actor://proj-quartz/memory-curator"
        ],
        "sourceUri": "library://proj-quartz/.meta-harness.json",
        "guidanceUri": "library://meta-harness/storage/STORAGE.md"
      }
    ]
  }
}
